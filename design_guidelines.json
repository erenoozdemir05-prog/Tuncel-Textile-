{
  "theme": "dark",
  "archetype": "5 (Jewel & Luxury)",
  "aesthetic_vision": {
    "vibe": "Ultra-premium, cinematic, dark luxury, mysterious, fashion campaign aesthetic",
    "references": "Rick Owens, Balenciaga, Saint Laurent, Fear of God",
    "key_traits": ["Minimal but powerful", "Editorial lookbook feel", "Expensive typography", "Layered shadows", "Glass blur details", "Ultra clean spacing", "Deep contrast"]
  },
  "color_tokens": {
    "background": {
      "default": "#0a0a0b",
      "matte_black": "#0f0f11",
      "charcoal": "#1a1a1d",
      "smoked": "#2a2a2e",
      "overlay": "rgba(0, 0, 0, 0.4)"
    },
    "text": {
      "primary": "#F5F4F0",
      "secondary": "#a1a1a5",
      "accent": "#C8B38A",
      "inverse": "#0a0a0b"
    },
    "border": {
      "subtle": "rgba(255, 255, 255, 0.05)",
      "medium": "rgba(255, 255, 255, 0.1)",
      "accent": "#C8B38A"
    },
    "interactive": {
      "hover_bg": "#1a1a1d",
      "focus_ring": "#C8B38A",
      "selection_bg": "#C8B38A",
      "selection_text": "#0a0a0b"
    }
  },
  "typography": {
    "font_families": {
      "display": "Bebas Neue, sans-serif",
      "body": "Manrope, sans-serif"
    },
    "scale": {
      "h1_hero": "text-7xl md:text-8xl lg:text-9xl uppercase tracking-tighter leading-[0.85]",
      "h2_section": "text-5xl md:text-6xl uppercase tracking-tight leading-none",
      "h3_card": "text-2xl md:text-3xl uppercase tracking-tight",
      "body_large": "text-lg md:text-xl font-light tracking-wide leading-relaxed",
      "body_base": "text-sm md:text-base font-light tracking-wide leading-relaxed",
      "overline": "text-xs md:text-sm uppercase tracking-[0.2em] text-secondary",
      "button": "text-sm uppercase tracking-[0.15em] font-medium"
    },
    "rules": {
      "alignment": "Never center paragraphs. Use aggressive asymmetry for display headers. Center only for absolute hero balance.",
      "hierarchy": "Extreme contrast between massive display fonts and tiny uppercase overlines."
    }
  },
  "spacing_rhythm": {
    "section_gap": "py-24 md:py-40",
    "element_gap": "gap-8 md:gap-12",
    "container_padding": "px-6 md:px-12 lg:px-24",
    "bento_gap": "gap-2 md:gap-4"
  },
  "animation_specs": {
    "scroll_reveal": "transition-all duration-1000 ease-out translate-y-8 opacity-0 data-[in-view=true]:translate-y-0 data-[in-view=true]:opacity-100",
    "hover_image": "transition-transform duration-700 ease-[cubic-bezier(0.25,1,0.5,1)] hover:scale-105",
    "hover_button": "transition-all duration-300 ease-out hover:bg-white hover:text-black",
    "page_load": "fade-in duration-1000",
    "glass_blur": "backdrop-blur-xl backdrop-saturate-150 bg-black/40"
  },
  "css_patterns": {
    "film_grain": "absolute inset-0 z-0 pointer-events-none opacity-[0.03] mix-blend-overlay bg-[url('data:image/svg+xml;base64,')]",
    "gold_foil": "bg-gradient-to-br from-[#E2D1A7] via-[#C8B38A] to-[#9B8454] text-transparent bg-clip-text",
    "luxury_border": "border border-white/5",
    "magnetic_button": "relative overflow-hidden group"
  },
