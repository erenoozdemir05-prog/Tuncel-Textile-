  "assembly_order": [
    "Navbar (Sticky, glass blur, dark)",
    "PremiumSplitHero (Existing, preserved but with improved grain)",
    "CampaignShowcase (New, replaces 3-card drop, cinematic layout)",
    "FeaturedProducts (New, minimal Rick Owens style grid)",
    "EditorialManifesto (New, split screen atelier story)",
    "BespokeCTA (Re-skinned to luxury dark aesthetic)",
    "GiftCardCTA (Re-skinned with gold accents)",
    "Newsletter (Re-skinned minimal)",
    "Footer (Massive typography, dark)"
  ],
  "components_breakdown": {
    "PremiumSplitHero": {
      "status": "KEEP & REFINE",
      "instructions": "Maintain functionality. Ensure grain texture overlay covers the entire hero. Use translation keys for button text."
    },
    "CampaignShowcase": {
      "status": "NEW",
      "instructions": "Full-bleed section. Massive typography 'EDITION 01 / STATIC NOISE'. Image takes up 80% width on right, text overlaps on left. Use 'campaign_hero' image."
    },
    "EditorialProductCard": {
      "status": "NEW",
      "instructions": "Extremely minimal. Image container with luxury border. Product name in small overline font, price next to it. No 'Add to cart' button visible until hover."
    },
    "EditorialManifesto": {
      "status": "NEW",
      "instructions": "Magazine spread layout. Left side: large serif/body text manifesto. Right side: 'atelier_texture' image. Asymmetric spacing."
    },
    "BespokeCTA": {
      "status": "RE-SKIN",
      "instructions": "Dark charcoal background. Subtle film grain. Minimal input fields with bottom-border only (no boxes)."
    },
    "GiftCardCTA": {
      "status": "RE-SKIN",
      "instructions": "Use 'gift_card_bg' as the main visual. Typography uses the gold_foil CSS pattern for the word 'GIFT'."
    }
  },
